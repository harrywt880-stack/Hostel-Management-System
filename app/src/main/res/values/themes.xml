<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.HostelManagementSystem" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.HostelManagementSystem" parent="Base.Theme.HostelManagementSystem" />

    <style name="DashboardCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">128dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/dashboard_card_bg</item>
        <item name="android:elevation">5dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#0F172A</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="PremiumDashboardCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">145dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:background">@drawable/dashboard_card_bg</item>
        <item name="android:elevation">6dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">#0F172A</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">5dp</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="StatCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">86dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/stat_card_bg</item>
        <item name="android:elevation">4dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textColor">#0F172A</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
</resources>