<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/user_card_bg"
    android:elevation="5dp"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/roomNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Room 101"
        android:textColor="#0F172A"
        android:textSize="19sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/roomFloor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="1st Floor"
        android:textColor="#64748B"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/roomBeds"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="2/4 beds occupied"
        android:textColor="#64748B"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/roomStatus"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/role_badge_bg"
        android:gravity="center"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:text="AVAILABLE"
        android:textColor="#2563EB"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
