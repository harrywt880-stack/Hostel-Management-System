<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/backText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textColor="#2563EB"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Payments Center"
            android:textColor="#0F172A"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Assign hostel fees to students and manage payment statuses from one admin panel."
            android:textColor="#64748B"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/premium_card_bg"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Student Fee"
                android:textColor="#0F172A"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/studentSpinner"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/input_premium_bg"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <EditText
                android:id="@+id/feeTitleInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_premium_bg"
                android:hint="Fee title"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <EditText
                android:id="@+id/monthLabelInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_premium_bg"
                android:hint="Month label, for example May 2026"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <EditText
                android:id="@+id/amountInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_premium_bg"
                android:hint="Amount"
                android:inputType="numberDecimal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <EditText
                android:id="@+id/dueDateInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_premium_bg"
                android:hint="Due date YYYY-MM-DD"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <EditText
                android:id="@+id/adminNoteInput"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_premium_bg"
                android:gravity="top|start"
                android:hint="Admin note (optional)"
                android:inputType="textMultiLine"
                android:minLines="4"
                android:padding="18dp" />

            <Button
                android:id="@+id/createFeeBtn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/primary_button_bg"
                android:text="Create Fee"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="All Fees"
            android:textColor="#0F172A"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="#2563EB"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/emptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="#64748B"
            android:textSize="14sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/feesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
