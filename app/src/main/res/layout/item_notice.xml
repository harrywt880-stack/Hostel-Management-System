<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/user_card_bg"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/noticeTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Maintenance Update"
        android:textColor="#0F172A"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/noticeMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Water supply will be unavailable for one hour."
        android:textColor="#334155"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/noticeMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="By Admin • Sent to 12 users"
        android:textColor="#64748B"
        android:textSize="12sp" />

</LinearLayout>
