<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:id="@+id/backText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:textColor="#2563EB"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Daily Mess Planner"
            android:textColor="#0F172A"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Publish one full-day menu for breakfast, lunch, snacks and dinner, and keep every previous day in history."
            android:textColor="#64748B"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/premium_card_bg"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="20dp">

            <EditText
                android:id="@+id/planDateInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/input_premium_bg"
                android:hint="Plan date (YYYY-MM-DD)"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <EditText
                android:id="@+id/breakfastInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_premium_bg"
                android:hint="Breakfast"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <EditText
                android:id="@+id/lunchInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_premium_bg"
                android:hint="Lunch"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <EditText
                android:id="@+id/snacksInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_premium_bg"
                android:hint="Evening snacks"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <EditText
                android:id="@+id/dinnerInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_premium_bg"
                android:hint="Dinner"
                android:paddingStart="18dp"
                android:paddingEnd="18dp" />

            <EditText
                android:id="@+id/notesInput"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_premium_bg"
                android:gravity="top|start"
                android:hint="Optional notes"
                android:inputType="textMultiLine"
                android:minLines="4"
                android:padding="18dp" />

            <Button
                android:id="@+id/savePlanBtn"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/primary_button_bg"
                android:text="Save Daily Mess Plan"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Recent Plans"
            android:textColor="#0F172A"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/emptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textColor="#64748B"
            android:textSize="14sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/historyRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
