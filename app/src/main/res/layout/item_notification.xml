<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/user_card_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/notificationType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/section_badge_bg"
        android:paddingStart="10dp"
        android:paddingTop="5dp"
        android:paddingEnd="10dp"
        android:paddingBottom="5dp"
        android:text="ALERT"
        android:textColor="#2563EB"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notificationTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Room assigned"
        android:textColor="#0F172A"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/notificationMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Room details"
        android:textColor="#475569"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/notificationMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Updated recently"
        android:textColor="#64748B"
        android:textSize="12sp" />

</LinearLayout>
