<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/user_card_bg"
    android:elevation="4dp"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/complaintIdText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CMP-20260428-AB12"
            android:textColor="#2563EB"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/complaintStatusText"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/status_badge_blue"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="OPEN"
            android:textColor="#DC2626"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/complaintSubjectText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Water leakage in room"
        android:textColor="#0F172A"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/complaintDescriptionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Water is leaking near the window and making the room wet."
        android:textColor="#475569"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/complaintMetaText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="2026-04-28 10:30"
        android:textColor="#64748B"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/adminNotesText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/info_strip_bg"
        android:padding="12dp"
        android:text="Admin notes: Electrician assigned."
        android:textColor="#0F172A"
        android:textSize="13sp" />

</LinearLayout>
