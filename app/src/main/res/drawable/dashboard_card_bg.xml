<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#F7FBFF"
                android:endColor="#E8F1FF"
                android:angle="135" />
            <stroke
                android:width="1dp"
                android:color="#3B82F6" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <item>
        <shape>
            <gradient
                android:startColor="#FFFFFF"
                android:endColor="#F8FBFF"
                android:angle="135" />
            <stroke
                android:width="1dp"
                android:color="#D6E3F5" />
            <corners android:radius="24dp" />
        </shape>
    </item>

</selector>
